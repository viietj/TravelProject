@model TravelProject.Models.ViewModels.DestinationDetailsViewModel

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Destination.Name;
}

<div class="container mt-5">
    <div class="row">

        <!-- Cột trái: Ảnh + thông tin chính -->
        <div class="col-md-8">

            <!-- Ảnh -->
            @if (Model.Destination.ImageUrl != null)
            {
                <img src="@Model.Destination.ImageUrl"
                     class="img-fluid rounded w-100 mb-4"
                     style="height:400px; object-fit:cover;"
                     alt="@Model.Destination.Name"
                     onerror="this.src='/images/default.jpg'" />
            }

            <!-- Tên + badges -->
            <div class="mb-3">
                <span class="badge bg-danger me-2">@Model.Destination.Region</span>
                <span class="badge bg-secondary">@Model.Destination.Category</span>
                <span class="badge bg-warning text-dark ms-2">
                    <i class="fas fa-star me-1"></i>@Model.AverageRating.ToString("0.0")/5
                </span>
            </div>
            <h2>@Model.Destination.Name</h2>
            <p class="text-muted">
                <i class="fas fa-map-marker-alt me-1"></i>@Model.Destination.Address
            </p>
            <hr />

            <!-- Mô tả -->
            <h5>About this destination</h5>
            <p>@Model.Destination.Description</p>

            <!-- Bản đồ -->
            @if (Model.Destination.Latitude != null && Model.Destination.Longitude != null)
            {
                <h5 class="mt-4">Location</h5>
                <div class="ratio ratio-16x9 rounded overflow-hidden">
                    <iframe
                        src="https://www.google.com/maps?q=@Model.Destination.Latitude,@Model.Destination.Longitude&z=14&output=embed"
                        allowfullscreen loading="lazy">
                    </iframe>
                </div>
            }

            <div class="card shadow-sm border-0 mt-5 mb-4">
                <div class="card-header bg-danger text-white">
                    <h6 class="mb-0">Write a Review</h6>
                </div>
                <div class="card-body">
                    @if (TempData["CommentSuccess"] != null)
                    {
                        <div class="alert alert-success">@TempData["CommentSuccess"]</div>
                    }

                    @if (TempData["CommentError"] != null)
                    {
                        <div class="alert alert-danger">@TempData["CommentError"]</div>
                    }

                    <form asp-action="AddComment" method="post">
                        <input type="hidden" asp-for="Destination.DestinationID" />

                        <div class="mb-3">
                            <label class="form-label">Your name</label>
                            <input asp-for="UserName" class="form-control" placeholder="Enter your name" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Your rating</label>
                            <select asp-for="Rating" class="form-select">
                                <option value="5">5 stars - Excellent</option>
                                <option value="4">4 stars - Very good</option>
                                <option value="3">3 stars - Good</option>
                                <option value="2">2 stars - Fair</option>
                                <option value="1">1 star - Poor</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Your review</label>
                            <textarea asp-for="Content" class="form-control" rows="4" placeholder="Share your experience about this destination"></textarea>
                        </div>

                        <button type="submit" class="btn btn-danger">
                            <i class="fas fa-paper-plane me-2"></i>Submit Review
                        </button>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-header bg-light">
                    <h6 class="mb-0">Visitor Reviews (@Model.TotalComments)</h6>
                </div>
                <div class="card-body">
                    @if (Model.Comments.Any())
                    {
                        @foreach (var comment in Model.Comments)
                        {
                            <div class="border-bottom pb-3 mb-3">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <strong>@comment.UserName</strong>
                                    <small class="text-muted">@comment.CreatedDate.ToString("dd/MM/yyyy HH:mm")</small>
                                </div>
                                <div class="mb-2 text-warning">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        if (i <= comment.Rating)
                                        {
                                            <i class="fas fa-star"></i>
                                        }
                                        else
                                        {
                                            <i class="far fa-star"></i>
                                        }
                                    }
                                </div>
                                <p class="mb-0">@comment.Content</p>
                            </div>
                        }
                    }
                    else
                    {
                        <p class="text-muted mb-0">No reviews yet. Be the first to review this destination.</p>
                    }
                </div>
            </div>

        </div>

        <!-- Cột phải: Thông tin nhanh -->
        <div class="col-md-4">

            <!-- Info card -->
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-danger text-white">
                    <h6 class="mb-0">Quick Info</h6>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled mb-0">
                        <li class="mb-2">
                            <i class="fas fa-globe me-2 text-danger"></i>
                            <strong>Region:</strong> @Model.Destination.Region
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-tag me-2 text-danger"></i>
                            <strong>Category:</strong> @Model.Destination.Category
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-eye me-2 text-danger"></i>
                            <strong>Views:</strong> @Model.Destination.ViewCount
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-star me-2 text-danger"></i>
                            <strong>Rating:</strong> @Model.AverageRating.ToString("0.0")/5
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-comments me-2 text-danger"></i>
                            <strong>Reviews:</strong> @Model.TotalComments
                        </li>
                        <li class="mb-2">
                            <i class="fas fa-calendar me-2 text-danger"></i>
                            <strong>Added:</strong> @Model.Destination.CreatedDate.ToString("dd/MM/yyyy")
                        </li>
                    </ul>
                </div>
            </div>

            <!-- Nút yêu thích -->
            <div class="d-grid mb-3">
                <a href="#" class="btn btn-outline-danger">
                    <i class="fas fa-heart me-2"></i>Add to Favorites
                </a>
            </div>

            <!-- Nút back -->
            <div class="d-grid">
                <a href="/Destination/Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-2"></i>Back to Destinations
                </a>
            </div>

        </div>
    </div>
</div>

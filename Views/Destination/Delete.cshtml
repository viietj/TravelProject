@{
    Layout = "_AdminLayout";
}
@model TravelProject.Models.Destination

@{
    ViewData["Title"] = "Delete Destination";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>Delete Destination</h2>
            <div class="alert alert-danger">
                Are you sure you want to delete <strong>@Model.Name</strong>?
            </div>
            <dl class="row">
                <dt class="col-sm-4">Region</dt>
                <dd class="col-sm-8">@Model.Region</dd>
                <dt class="col-sm-4">Category</dt>
                <dd class="col-sm-8">@Model.Category</dd>
                <dt class="col-sm-4">Address</dt>
                <dd class="col-sm-8">@Model.Address</dd>
            </dl>
            <form method="post">
                <button type="submit" class="btn btn-danger">Yes, Delete</button>
                <a href="/Destination/Index" class="btn btn-secondary">Cancel</a>
            </form>
        </div>
    </div>
</div>
<!DOCTYPE html>
<html lang="en">
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin</title>

    <!-- Google Fonts -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css?family=Source+Sans+Pro:300,400,400i,700&display=fallback" />
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <!-- AdminLTE CSS -->
    <link rel="stylesheet" href="~/adminlte/css/adminlte.min.css" />
</head>
<body class="layout-fixed sidebar-expand-lg bg-body-tertiary">

<div class="app-wrapper">

    <!-- Navbar -->
    <nav class="app-header navbar navbar-expand bg-body">
        <div class="container-fluid">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                        <i class="bi bi-list"></i>
                    </a>
                </li>
            </ul>
            <a href="/Home/Index" class="navbar-brand ms-2">
                <b>Travel</b>Vietnam
            </a>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <span class="nav-link">
                        <i class="fas fa-user me-1"></i>
                        @HttpContextAccessor.HttpContext.Session.GetString("Username")
                    </span>
                </li>
                <li class="nav-item">
                    <a href="/Account/Logout" class="nav-link text-danger">
                        <i class="fas fa-sign-out-alt me-1"></i> Logout
                    </a>
                </li>
            </ul>
        </div>
    </nav>

    <!-- Sidebar -->
    <aside class="app-sidebar bg-dark shadow" data-bs-theme="dark">
        <div class="sidebar-brand p-3">
            <span class="brand-text fw-bold">
                <i class="fas fa-globe me-2"></i>Admin Panel
            </span>
        </div>
        <div class="sidebar-wrapper">
            <nav class="mt-2">
                <ul class="nav sidebar-menu flex-column" role="menu">
                    <li class="nav-item">
                        <a href="/Admin/Index" class="nav-link">
                            <i class="nav-icon fas fa-tachometer-alt me-2"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Destination/Index" class="nav-link">
                            <i class="nav-icon fas fa-map-marker-alt me-2"></i>
                            Destinations
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/User/Index" class="nav-link">
                            <i class="nav-icon fas fa-users me-2"></i>
                            Users
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="/Tour/Index" class="nav-link">
                            <i class="nav-icon fas fa-route me-2"></i>
                            Tours
                        </a>
                    </li>
                </ul>
            </nav>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="app-main">
        <div class="app-content-header py-3">
            <div class="container-fluid">
                <h3 class="mb-0">@ViewData["Title"]</h3>
            </div>
        </div>
        <div class="app-content">
            <div class="container-fluid">
                @RenderBody()
            </div>
        </div>
    </main>

</div>

<!-- jQuery -->
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
<!-- Bootstrap 5 JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<!-- AdminLTE JS -->
<script src="~/adminlte/js/adminlte.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>